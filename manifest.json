{
  "manifest_version": 3,
  "name": "ChoiceAdvantage Enhanced",
  "version": "4.1",
  "description": "DNR alerts, table tools, escape back, and username-only memory",
  "permissions": ["storage", "contextMenus", "declarativeNetRequest"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "options.html"
  },
  "content_scripts": [
    {
      "matches": ["https://choiceadvantage.com/*", "https://*.choiceadvantage.com/*"],
      "js": ["settings.js", "fake-data.js", "content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["page.js"],
      "matches": ["https://choiceadvantage.com/*", "https://*.choiceadvantage.com/*"]
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon.png",
    "128": "icon128.png"
  }
}
