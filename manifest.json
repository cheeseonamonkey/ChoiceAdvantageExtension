{
  "manifest_version": 3,
  "name": "ChoiceAdvantage Enhanced",
  "version": "4.3",
  "description": "DNR highlighting, Escape-to-Back, explicit test-data inserts, and macro recording for ChoiceAdvantage",
  "permissions": ["storage", "contextMenus", "declarativeNetRequest", "activeTab", "webNavigation"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "options.html"
  },
  "content_scripts": [
    {
      "matches": ["https://choiceadvantage.com/*", "https://*.choiceadvantage.com/*"],
      "js": ["settings.js", "content.js", "macro-recorder-runtime.js"],
      "all_frames": true,
      "run_at": "document_start"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon.png",
    "128": "icon128.png"
  }
}
