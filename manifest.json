{
  "manifest_version": 3,
  "name": "ChoiceAdvantage Enhanced",
  "version": "4.0",
  "description": "DNR highlighting, hide columns, escape key",
  "permissions": ["storage", "contextMenus"],
  "host_permissions": ["https://choiceadvantage.com/*", "https://*.choiceadvantage.com/*"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "options.html"
  },
  "content_scripts": [
    {
      "matches": ["https://choiceadvantage.com/*", "https://*.choiceadvantage.com/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icon16.png",
    "48": "icon.png",
    "128": "icon128.png"
  }
}
